APP_NAME=knowledge-graph-hybrid-rag
ENVIRONMENT=development
RAW_DATA_DIR=data/raw_pdfs
PARSED_DATA_DIR=data/parsed
EXTRACTED_DATA_DIR=data/extracted
VECTOR_STORE_PATH=data/vector_store.json
GRAPH_BACKEND=neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=knowledgegraph
OPENROUTER_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-5.4-mini
OPENROUTER_HTTP_REFERER=
OPENROUTER_TITLE=knowledge-graph-hybrid-rag
ENABLE_LLM_EXTRACTION=true
LLM_EXTRACTION_MAX_CHUNKS=25
LLM_USAGE_LOG_PATH=data/llm_usage.jsonl
LLM_INPUT_COST_PER_MILLION=
LLM_OUTPUT_COST_PER_MILLION=
LLM_COST_CURRENCY=USD